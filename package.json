{
  "name": "@fairspec/typescript",
  "version": "0.0.0-dev",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "deps": "ncu -ws -u",
    "coverage": "sensible-browser coverage/index.html",
    "debug": "vp test --no-file-parallelism --test-timeout=0 --inspect-brk --browser run",
    "docs:build": "livemark build",
    "docs:start": "livemark start",
    "format": "vp fmt",
    "leaks": "gitleaks git --config=.gitleaks.toml --verbose --redact",
    "lint": "vp fmt --check && vp lint",
    "prepare": "lefthook install",
    "preview": "livemark preview",
    "release": "pnpm -r publish --access public --ignore-scripts --no-git-checks",
    "scan": "pnpm leaks && pnpm vulns",
    "vers": "pnpm -r exec pnpm version --no-git-tag-version",
    "unit": "vp test",
    "test": "pnpm lint && pnpm build && pnpm unit",
    "test:win": "pnpm unit",
    "type": "pnpm -r type",
    "vulns": "semgrep --config=p/typescript --config=p/nodejs --config=p/owasp-top-ten --config=p/secrets --exclude='**/fixtures/**' --metrics=off"
  },
  "devDependencies": {
    "@plausible-analytics/tracker": "0.4.5",
    "@semantic-release/exec": "7.1.0",
    "@tanstack/react-router": "1.169.2",
    "@tanstack/react-start": "1.167.65",
    "@types/node": "24.2.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.0",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "@vitest/coverage-v8": "4.1.0",
    "conventional-changelog-conventionalcommits": "9.1.0",
    "execa": "9.6.0",
    "lefthook": "2.1.1",
    "livemark": "0.20.0",
    "lucide-react": "0.577.0",
    "npm-check-updates": "18.0.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "semantic-release": "24.2.9",
    "tempy": "3.1.0",
    "type-fest": "4.41.0",
    "vite-plus": "0.1.14",
    "vitest-polly": "2.1.0",
    "wrangler": "4.90.0"
  },
  "engines": {
    "node": "^24.0.0",
    "pnpm": "^11.0.0"
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
}
