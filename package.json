{
  "name": "@fairspec/typescript",
  "version": "0.0.0-dev",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "bump": "ncu -ws -u",
    "clean": "rm -rf pnpm-local.yaml node_modules **/node_modules **/build .livemark/build",
    "coverage": "sensible-browser coverage/index.html",
    "debug": "vp test --no-file-parallelism --test-timeout=0 --inspect-brk --browser run",
    "docs:build": "livemark build",
    "docs:start": "livemark start",
    "format": "vp fmt",
    "lint": "vp fmt --check && vp lint",
    "prepare": "is-ci || lefthook install",
    "preview": "livemark preview",
    "release": "pnpm -r publish --access public --ignore-scripts --no-git-checks",
    "setversion": "pnpm -r exec pnpm version --no-git-tag-version",
    "unit": "vp test",
    "test": "pnpm lint && pnpm build && pnpm unit",
    "test:win": "pnpm unit",
    "type": "pnpm -r type"
  },
  "devDependencies": {
    "@plausible-analytics/tracker": "0.4.5",
    "@semantic-release/exec": "7.1.0",
    "@tanstack/react-router": "1.169.2",
    "@tanstack/react-start": "1.167.65",
    "@types/node": "24.2.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.0",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "@vitest/coverage-v8": "4.1.0",
    "conventional-changelog-conventionalcommits": "9.1.0",
    "execa": "9.6.0",
    "is-ci": "4.1.0",
    "lefthook": "2.1.1",
    "livemark": "0.13.1",
    "lucide-react": "0.577.0",
    "npm-check-updates": "18.0.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "semantic-release": "24.2.9",
    "tempy": "3.1.0",
    "type-fest": "4.41.0",
    "vite-plus": "0.1.14",
    "vitest-polly": "2.1.0",
    "wrangler": "4.90.0"
  },
  "engines": {
    "node": "^24.0.0",
    "pnpm": "^10.0.0"
  },
  "packageManager": "pnpm@10.21.0+sha512.da3337267e400fdd3d479a6c68079ac6db01d8ca4f67572083e722775a796788a7a9956613749e000fac20d424b594f7a791a5f4e2e13581c5ef947f26968a40"
}
